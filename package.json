  "scripts": {
    "dev": "concurrently --prefix-colors \"cyan,yellow,magenta\" --names \"FRONTEND,BACKEND,ENGINE\" \"vite --port=3000 --host=0.0.0.0\" \"cd backend && npm run dev\" \"cd deploy_generation_engine && npm run dev\"",
